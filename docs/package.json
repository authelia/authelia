{
  "name": "authelia-website",
  "version": "1.9.0",
  "description": "The Authelia Website",
  "author": "Authelia Contributors",
  "license": "Apache-2.0",
  "scripts": {
    "create": "hugo new",
    "dev": "hugo server --disableFastRender --noHTTPCache",
    "format": "prettier **/** -w -c",
    "build": "hugo --minify --gc",
    "preview": "vite preview --outDir public"
  },
  "dependencies": {
    "@docsearch/css": "3.9.0",
    "@docsearch/js": "3.9.0",
    "@tabler/icons": "3.40.0",
    "@thulite/doks-core": "1.9.3",
    "@thulite/images": "3.3.4",
    "@thulite/inline-svg": "1.2.2",
    "@thulite/seo": "2.4.3",
    "bootstrap-icons": "1.13.1",
    "thulite": "^2.6.5"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.5.2",
    "@changesets/cli": "2.29.8",
    "prettier": "3.8.1",
    "vite": "7.3.1"
  },
  "overrides": {
    "minimatch": "10.2.2",
    "glob": "13.0.6"
  },
  "engines": {
    "node": ">=24.13.0",
    "pnpm": "10"
  },
  "packageManager": "pnpm@10.6.4",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "pnpm": {
    "overrides": {
      "yauzl@<3.2.1": "3.2.1",
      "semver@>=7.0.0 <7.5.2": "7.5.2"
    }
  }
